# Base URL of the FastAPI backend.
# Local:  http://localhost:8000
# Instance: http://13.48.30.153:8000
VITE_API_BASE=http://localhost:8000

# PostHog product analytics (optional). Leave BLANK to disable — the app then
# loads no analytics at all. Set the PUBLIC project key (starts with "phc_") in
# the production build to track usage (questions asked, guardrail blocks).
VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.i.posthog.com   # use us.i.posthog.com for US cloud
